PORT=3000

# --- Database (leave empty to use sample JSON file instead) ---
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/gp_dashboard

# --- Pipeline mode (no database) ---
# Start empty so the upload flow fills the dashboard fresh.
# After uploading a video the app hot-swaps to the new run automatically.
SAMPLE_DATA_PATH=data/empty.json
MEDIA_ROOT_PATH=pipeline
MEDIA_BASE_URL=http://localhost:3000/media
