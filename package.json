    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
